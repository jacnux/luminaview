/* Import Google Font */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');

:root {
  --primary: #fbbf24; /* Jaune Or */
  --bg-dark: #0f0f0f;
  --bg-card: rgba(255, 255, 255, 0.05);
  --text-main: #e5e5e5;
  --text-muted: #a3a3a3;
  --radius: 12px;
}

body {
  margin: 0;
  font-family: 'Inter', sans-serif;
  background-color: var(--bg-dark);
  color: var(--text-main);
  -webkit-font-smoothing: antialiased;
  line-height: 1.6;
}

/* --- NAVBAR --- */
.navbar {
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  padding: 1rem 2rem;
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.navbar-brand {
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.navbar-brand span {
  background: linear-gradient(45deg, var(--primary), #f59e0b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.nav-link {
  color: var(--text-muted);
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s;
  padding: 0.5rem 1rem;
  border-radius: 8px;
}

.nav-link:hover {
  color: white;
  background: rgba(255, 255, 255, 0.1);
}

/* --- CONTAINER --- */
.container {
  max-width: 900px;
  margin: 0 auto;
  padding: 2rem 1rem;
}

/* --- CARDS (Articles & Galeries) --- */
.card {
  background: var(--bg-card);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius);
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  transition: transform 0.2s, box-shadow 0.2s;
}

.card:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  border-color: rgba(255, 255, 255, 0.15);
}

.card-link {
  text-decoration: none;
  color: inherit;
}

.card-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
  margin: 0 0 0.5rem 0;
  line-height: 1.3;
}

.card-date {
  font-size: 0.85rem;
  color: var(--primary);
  font-weight: 600;
  margin-bottom: 1rem;
  display: block;
}

.card-excerpt {
  color: var(--text-muted);
  font-size: 0.95rem;
}

/* --- ARTICLE DETAIL (Markdown) --- */
.prose {
  font-size: 1.1rem;
  line-height: 1.8;
  color: #d4d4d4;
}

.prose h1 { font-size: 2.5rem; margin-bottom: 1rem; color: white; border-bottom: 1px solid #333; padding-bottom: 1rem; }
.prose h2 { font-size: 1.8rem; color: white; margin-top: 2rem; }
.prose p { margin-bottom: 1.5rem; }
.prose a { color: var(--primary); text-decoration: underline; }
.prose img {
  border-radius: var(--radius);
  margin: 2rem auto;
  display: block;
  max-width: 100%;
  box-shadow: 0 5px 15px rgba(0,0,0,0.5);
}
.prose blockquote {
  border-left: 4px solid var(--primary);
  padding-left: 1.5rem;
  margin: 1.5rem 0;
  color: var(--text-muted);
  font-style: italic;
}

/* --- GALLERY GRID --- */
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
}

.gallery-card {
  display: block;
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
  text-decoration: none;
  color: white;
  border: 1px solid rgba(255,255,255,0.05);
  transition: transform 0.3s;
}

.gallery-card:hover {
  transform: scale(1.02);
}

.gallery-thumb {
  aspect-ratio: 16/9;
  background: #222;
  overflow: hidden;
}

.gallery-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s;
}

.gallery-card:hover .gallery-thumb img {
  transform: scale(1.1);
}

.gallery-info {
  padding: 1rem;
  text-align: center;
}

/* --- ABOUT PAGE --- */
.about-avatar {
  width: 150px;
  height: 150px;
  border-radius: 50%;
  border: 4px solid var(--primary);
  object-fit: cover;
  margin-bottom: 1.5rem;
  box-shadow: 0 0 20px rgba(251, 191, 36, 0.2);
}

/* --- BUTTONS --- */
.btn {
  display: inline-block;
  padding: 0.6rem 1.2rem;
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.2s;
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: black;
}

.btn-primary:hover {
  background: #f59e0b;
  box-shadow: 0 0 15px rgba(251, 191, 36, 0.4);
}

.btn-ghost {
  background: transparent;
  border: 1px solid rgba(255,255,255,0.2);
  color: white;
}

.btn-ghost:hover {
  background: rgba(255,255,255,0.1);
}

/* --- FORMS --- */
.input-group {
  margin-bottom: 1rem;
}

.input-label {
  display: block;
  font-size: 0.85rem;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.input-field {
  width: 100%;
  padding: 0.8rem 1rem;
  border-radius: 8px;
  border: 1px solid #333;
  background: #1a1a1a;
  color: white;
  font-family: inherit;
  font-size: 1rem;
  transition: border-color 0.2s;
}

.input-field:focus {
  outline: none;
  border-color: var(--primary);
}

/* Helpers */
.text-center { text-align: center; }
.text-left { text-align: left; }
.mt-4 { margin-top: 2rem; }
.mb-4 { margin-bottom: 2rem; }
